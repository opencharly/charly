{
  "includeCoAuthoredBy": false,
  "worktree": {
    "bgIsolation": "none"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "auto",
  "permissions": {
    "allow": [
      "Bash(charly check run:*)",
      "Bash(charly check live:*)",
      "Bash(charly check box:*)",
      "Bash(charly status:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh api --method POST repos/opencharly:*)"
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "OpenCharly Validated Landing: In the opencharly org only, a FRESH pr-validator sub-agent — spawned with new context, never the PR's author, having independently re-validated the PR against CLAUDE.md R0-R10 — may post the `charly/claude-validation` commit status on that PR, merge it with `gh pr merge --rebase --delete-branch`, and push the merge-time annotated `v<CalVer>` tag. The operator NAMES and grants standing authorization for the two soft blocks this triggers: approving it yourself (a required check stamped on a PR this session authored) and merging without review (no separate human approval). This is accepted knowingly as agent-ATTESTED validation, not two-party review. Covers: the status POST, the rebase merge, the annotated tag push, and the merge-time CalVer version-stamp commit. Does NOT cover: `gh pr merge --admin` or `--force`; force-push on any branch; editing branch protection or marking a required check not-required; disabling CI; a PR's own author self-posting its status (only a fresh pr-validator posts it); posting a status on a PR the agent did not itself validate; or any repository outside the opencharly org."
    ]
  },
  "enabledPlugins": {
    "charly-core@charly-plugins": true,
    "charly-build@charly-plugins": true,
    "charly-check@charly-plugins": true,
    "charly-automation@charly-plugins": true,
    "charly-image@charly-plugins": true,
    "charly-vm@charly-plugins": true,
    "charly-kubernetes@charly-plugins": true,
    "charly-local@charly-plugins": true,
    "charly-pod@charly-plugins": true,
    "charly-internals@charly-plugins": true,
    "charly-distros@charly-plugins": true,
    "charly-languages@charly-plugins": true,
    "charly-infrastructure@charly-plugins": true,
    "charly-tools@charly-plugins": true,
    "charly-jupyter@charly-plugins": true,
    "charly-coder@charly-plugins": true,
    "charly-selkies@charly-plugins": true,
    "charly-openclaw@charly-plugins": true,
    "charly-versa@charly-plugins": true,
    "charly-ollama@charly-plugins": true,
    "charly-openwebui@charly-plugins": true,
    "charly-comfyui@charly-plugins": true,
    "charly-immich@charly-plugins": true,
    "charly-hermes@charly-plugins": true,
    "charly-filebrowser@charly-plugins": true,
    "claude-md-management@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "charly-plugins": {
      "source": {
        "source": "directory",
        "path": "./plugins"
      }
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/runtime-verification-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/end-of-turn-challenge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-gate.sh"
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-gate.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/team-coordination-reminder.sh"
          }
        ]
      }
    ]
  }
}

#!/bin/sh
# kde-selkies-session: start a full KDE Plasma Wayland session NESTED inside
# pixelflux's virtual Wayland compositor (wayland-1), so selkies streams the
# Plasma desktop over WebRTC. This is the KDE analogue of labwc-wrapper:
# pixelflux owns wayland-1; KWin/Plasma renders into it; pixelflux captures +
# H.264/NVENC-encodes the composited frames. (This streamed session is the
# pixelflux virtual framebuffer — distinct from the SDDM/Plasma DRM session a
# physical monitor shows on the real GPU.)

PIXELFLUX_SOCKET="${XDG_RUNTIME_DIR:-/tmp}/wayland-1"
TIMEOUT=60
ELAPSED=0
echo "kde-selkies-session: waiting for pixelflux socket at $PIXELFLUX_SOCKET..."
while [ ! -e "$PIXELFLUX_SOCKET" ] && [ "$ELAPSED" -lt "$TIMEOUT" ]; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
done
if [ ! -e "$PIXELFLUX_SOCKET" ]; then
    echo "kde-selkies-session: pixelflux socket not ready after ${TIMEOUT}s" >&2
    exit 1
fi
echo "kde-selkies-session: socket found, starting nested KDE Plasma (Wayland)"

# Render into pixelflux's compositor, not the GPU scanout.
export WAYLAND_DISPLAY=wayland-1
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=KDE
export XDG_SESSION_DESKTOP=KDE
export KWIN_DRM_NO_AMS=1
export XCURSOR_THEME=breeze_cursors
export XCURSOR_SIZE=24
export XKB_DEFAULT_LAYOUT="${XKB_DEFAULT_LAYOUT:-us}"
export XKB_DEFAULT_VARIANT="${XKB_DEFAULT_VARIANT:-}"
export XKB_DEFAULT_MODEL="${XKB_DEFAULT_MODEL:-pc105}"
export XKB_DEFAULT_OPTIONS="${XKB_DEFAULT_OPTIONS:-}"

# Chrome (CDP) is NOT launched here — the supervised `[program:chrome]` service
# in the selkies-core layer owns it for both selkies flavors. chrome-wrapper
# polls for wayland-0 (the Plasma client socket startplasma-wayland creates
# below) itself, and supervisord relaunches Chrome if it self-exits during the
# nested compositor's startup-race (the former fire-once launch here had no such
# relaunch, so Chrome stayed dead). See candy/selkies-core/candy.yml.

# A private D-Bus session so this nested Plasma doesn't collide with the DRM
# Plasma session's bus.
#
# Launch kwin_wayland DIRECTLY as a NESTED compositor with the explicit
# `--wayland-display wayland-1` flag -- NOT via startplasma-wayland. RCA (proven on
# a live bed: blank 4046-byte frame -> real 45746-byte frame): in this systemd-less
# pod startplasma-wayland falls back to the legacy plasma_session shim, which starts
# kwin on the HEADLESS backend (kwin holds NO connection to pixelflux's wayland-1 and
# opens NO /dev/dri -- it renders into an off-screen buffer nothing captures, so the
# stream is a uniform black frame). The `--wayland-display wayland-1` flag is what
# makes kwin NEST into pixelflux and present its composited output there -- the KDE
# analogue of how labwc auto-nests from WAYLAND_DISPLAY (labwc is wlroots and nests
# implicitly; kwin needs the flag). kwin creates its own wayland-0 client socket for
# plasmashell + Chrome. (kwin_wayland is launched WITHOUT its cap_sys_nice file
# capability -- stripped by the kde-selkies-kwin-strip-caps build step -- because the
# pod's no-new-privileges rejects exec of a file-capability binary: `Operation not
# permitted`. The DRM/seat cap is unneeded when nesting into pixelflux.)
exec dbus-run-session sh -c '
    kwin_wayland --wayland-display wayland-1 --xwayland --width 1280 --height 720 &
    kwin_pid=$!
    kwin_socket="${XDG_RUNTIME_DIR:-/tmp}/wayland-0"
    waited=0
    while [ ! -e "$kwin_socket" ] && [ "$waited" -lt 120 ]; do
        sleep 0.5
        waited=$((waited + 1))
    done
    if [ -e "$kwin_socket" ]; then
        echo "kde-selkies-session: kwin wayland-0 socket up, launching plasmashell"
        WAYLAND_DISPLAY=wayland-0 plasmashell &
    else
        echo "kde-selkies-session: kwin wayland-0 socket never appeared in 60s; plasmashell not launched" >&2
    fi
    wait "$kwin_pid"
'
